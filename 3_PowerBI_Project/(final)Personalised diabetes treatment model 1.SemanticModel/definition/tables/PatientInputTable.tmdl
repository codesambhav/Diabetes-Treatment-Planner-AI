table PatientInputTable
	lineageTag: 57563b1c-173c-4764-a546-927a7da987cb

	measure 'Best Predicted HbA1c' = MIN(output_df[Predicted_Future_HbA1c])
		lineageTag: 69c377a6-f9d0-43ad-acbc-99515d2c7c3c

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Best Recommended Treatment' =
			
			VAR Diagnosis = SELECTEDVALUE(output_df[Diagnosis])
			RETURN
			IF(
			    Diagnosis = "Not Diabetic",
			    "N/A",
			    // This part runs only if the patient is diabetic
			    MINX(
			        TOPN(
			            1,
			            output_df,
			            output_df[Predicted_Future_HbA1c],
			            ASC
			        ),
			        output_df[Treatment_Option]
			    )
			)
		lineageTag: d35898b3-c545-4a85-9498-949201c2554c

	measure 'Best Treatment Description' =
			
			VAR Diagnosis = SELECTEDVALUE(output_df[Diagnosis])
			RETURN
			IF(
			    Diagnosis = "Not Diabetic",
			    "No treatment details required.",
			    LOOKUPVALUE(
			        TreatmentDetails[Description],
			        TreatmentDetails[Treatment_Name],
			        [Best Recommended Treatment]
			    )
			)
		lineageTag: c454ccf3-91e7-4281-9b93-2a51226b4cbe

	measure 'Best Treatment MoA' =
			
			VAR Diagnosis = SELECTEDVALUE(output_df[Diagnosis])
			RETURN
			IF(
			    Diagnosis = "Not Diabetic",
			    "",
			    LOOKUPVALUE(
			        TreatmentDetails[Mechanism_of_Action],
			        TreatmentDetails[Treatment_Name],
			        [Best Recommended Treatment]
			    )
			)
		lineageTag: 0f2418dd-d05f-4d34-87e4-6450c0698221

