	partition PatientInputTable = m
		mode: import
		source = ```
				let
				    Source = #table(
				        type table[
				            Age=number, BMI=number, HbA1c=number, Fasting_Glucose=number, 
				            Family_History=number, Hypertension=number, Is_Pregnant=number, 
				            Kidney_Function=text
				        ], 
				        {
				            {p_Age, p_BMI, p_HbA1c, p_Fasting_Glucose, p_Family_History, p_Hypertension, p_Is_Pregnant, p_Kidney_Function}
				        }
				    )
				in
				    Source
				```

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

